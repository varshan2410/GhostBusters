SERVICE_NAME=ghostbusters
STATIC_DIR=static
DATABASE_URL=postgresql://ghostbusters:ghostbusters@localhost:15432/ghostbusters
REDIS_URL=redis://localhost:6379/0
AUTO_CREATE_SCHEMA=true
CONFTEST_ENABLED=false
CONFTEST_EXECUTABLE=conftest
CONFTEST_POLICY_DIR=policies
CONFTEST_TIMEOUT_SECONDS=5
MINIMUM_POLICY_CONFIDENCE=0.70
EXTERNAL_RETRY_ENABLED=true
EXTERNAL_RETRY_MAX_ATTEMPTS=3
EXTERNAL_RETRY_INITIAL_DELAY_SECONDS=0.25
EXTERNAL_RETRY_MULTIPLIER=2
EXTERNAL_RETRY_MAX_DELAY_SECONDS=2
EXTERNAL_RETRY_JITTER_SECONDS=0.10
EXTERNAL_CALL_TIMEOUT_SECONDS=5
AI_ENABLED=false
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
GEMINI_API_VERSION=v1
GEMINI_TIMEOUT_SECONDS=10
GEMINI_MAX_PLANNING_STEPS=6
GEMINI_TEMPERATURE=0.1
AI_DETERMINISTIC_FALLBACK_ENABLED=true
CLOUD_HUNT_ENABLED=true
CLOUD_HUNT_CANDIDATE_THRESHOLD=0.45
CLOUD_HUNT_HIGH_CONFIDENCE_THRESHOLD=0.75
CLOUD_HUNT_RESOURCE_AGE_DAYS=60
CLOUD_HUNT_ACTIVITY_LOOKBACK_DAYS=30
CLOUD_HUNT_UTILIZATION_LOOKBACK_DAYS=14
CLOUD_HUNT_LOW_CPU_THRESHOLD=10
GITHUB_INTEGRATION_ENABLED=false
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
GITHUB_ALLOWED_REPOSITORIES=
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_REQUEST_TIMEOUT_SECONDS=10
GITHUB_DEMO_REPOSITORY=
GITHUB_REMEDIATION_BRANCH_PREFIX=ghostbusters/remediation
GITHUB_CREATE_REAL_PR=false
TERRAFORM_CLI_ENABLED=false
TERRAFORM_BINARY=terraform
TERRAFORM_TIMEOUT_SECONDS=60
TERRAFORM_WORK_ROOT=.runtime/terraform
TERRAFORM_ALLOW_INIT=false
TERRAFORM_ALLOW_NETWORK=false
